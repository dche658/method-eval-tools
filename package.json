{
  "name": "excel-addin-metools",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/dche658/method-eval-tools.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "excel",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch",
    "test": "jest",
    "copy": "node ./etc/copy-files.mjs"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-icons": "^2.0.326",
    "core-js": "^3.49.0",
    "es6-promise": "^4.2.8",
    "jstat-esm": "^2.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/custom-functions-runtime": "^1.6.11",
    "@types/jest": "^30.0.0",
    "@types/office-js": "^1.0.589",
    "@types/office-runtime": "^1.0.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack": "^5.28.5",
    "acorn": "^8.16.0",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "custom-functions-metadata-plugin": "^2.1.7",
    "eslint-plugin-office-addins": "^4.0.7",
    "eslint-plugin-react": "^7.37.5",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "office-addin-cli": "^2.0.7",
    "office-addin-debugging": "^6.0.7",
    "office-addin-dev-certs": "^2.0.7",
    "office-addin-lint": "^3.0.7",
    "office-addin-manifest": "^2.1.3",
    "office-addin-prettier-config": "^2.0.2",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.4.2",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
